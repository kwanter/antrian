# Antrian — Environment Defaults
#
# This file is a TEMPLATE. Copy to `.env` on every deploy and override the
# placeholders below. Defaults aim at LAN-only deployment; for any internet-
# facing deploy, REVIEW every placeholder before use.
#
# Required per-environment overrides (deploy checklist):
#   - APP_KEY                       : `php artisan key:generate` after copy
#   - REVERB_APP_KEY / SECRET       : random strings per env, never reused
#   - APP_DEBUG                     : must be `false` in production
#   - APP_URL                       : real scheme://hostname[:port]
#   - SANCTUM_STATEFUL_DOMAINS      : SPA's origin exactly (scheme + host[:port])
#   - CORS_ALLOWED_ORIGINS          : same SPA origin, comma-separated

APP_NAME=Antrian
APP_ENV=local
APP_TIMEZONE=Asia/Makassar
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

SANCTUM_STATEFUL_DOMAINS=localhost:3000

REVERB_ENABLED=true
REVERB_APP_ID=antrian
REVERB_APP_KEY=<replace-with-php-artisan-reverb:key>
REVERB_APP_SECRET=<replace-with-php-artisan-reverb:key>
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

PUSHER_APP_ID="${REVERB_APP_ID}"
PUSHER_APP_KEY="${REVERB_APP_KEY}"
PUSHER_APP_SECRET="${REVERB_APP_SECRET}"
PUSHER_HOST="${REVERB_HOST}"
PUSHER_PORT="${REVERB_PORT}"
PUSHER_SCHEME="${REVERB_SCHEME}"
